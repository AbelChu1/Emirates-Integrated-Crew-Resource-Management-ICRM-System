        "# PHASE I: THE CHRONOLOGICAL ROSTER\n",
        "# We implement a singly linked list to manage a crew member's\n",
        "# monthly flight schedule in chronological order.\n",
        "\n",
        "\n",
        "class FlightNode:\n",
        "    \"\"\"\n",
        "    We use this class to represent a single flight in the crew roster.\n",
        "    Each node holds the flight details and a pointer to the next flight\n",
        "    in the chronological sequence. This node includes attributes of flight_nuber, destination,\n",
        "    Departure_time, arrival_time and next(FlightNode)\n",
        "    \"\"\"\n",
        "\n",
        "    def __init__(self, flight_number, destination, departure_time, arrival_time):\n",
        "        # We store the flight details as attributes of this node.\n",
        "        if not isinstance(departure_time, int) or not isinstance(arrival_time, int):\n",
        "            raise ValueError(\"Departure and arrival time must be integers\")\n",
        "\n",
        "        if departure_time > 2359 or arrival_time > 2359:\n",
        "            raise ValueError(\"Time must be in HHMM format (e.g., 1345)\")\n",
        "        else:\n",
        "            self.flight_number  = str(flight_number)\n",
        "            self.destination    = str(destination)\n",
        "            self.departure_time = departure_time\n",
        "            self.arrival_time   = arrival_time\n",
        "            # We initialise the next pointer to None because this node\n",
        "            # has not yet been linked to any other node.\n",
        "            self.next = None\n",
        "\n",
        "\n",
        "class CrewRoster:\n",
        "    \"\"\"\n",
        "    We use this class to represent the monthly flight roster for one crew member.\n",
        "    We implement it as a singly linked list. The list is always kept in\n",
        "    chronological order by departure time, regardless of the order in which\n",
        "    flights are added. It has attribute of head (FlightNode)which is\n",
        "    The first (earliest-departing) flight in the roster.\n",
        "    \"\"\"\n",
        "\n",
        "    def __init__(self):\n",
        "        # We start with an empty roster, so the head points to nothing.\n",
        "        self.head = None\n",
        "\n",
        "    # This is helper method which convert HHMM integer to total minutes.\n",
        "    # We use this in validate_rest to compare time gaps easily.\n",
        "    def _to_minutes(self, hhmm):\n",
        "        if not isinstance(hhmm, int):\n",
        "            raise ValueError(\"time must be integers\")\n",
        "        if hhmm > 2359 :\n",
        "            raise ValueError(\"Time must be in HHMM format (e.g., 1345)\")\n",
        "        \"\"\"\n",
        "        This converts a time value in HHMM format to the equivalent number\n",
        "        of minutes since midnight. For example, 0930 becomes 570 minutes. In\n",
        "        short, it takes argument as HHMM format and returns the total number of\n",
        "        minutes since midnight.\n",
        "        \"\"\"\n",
        "        hours   = hhmm // 100\n",
        "        minutes = hhmm % 100\n",
        "        return (hours * 60) + minutes\n",
        "\n",
        "    #--------------------------------------------------------------------------------\n",
        "\n",
        "    # Operation 1: Add a flight (sorted insertion).\n",
        "    def add_flight(self, flight_number, destination, departure_time, arrival_time):\n",
        "        if not isinstance(departure_time, int) or not isinstance(arrival_time, int):\n",
        "            raise ValueError(\"Departure and arrival time must be integers\")\n",
        "\n",
        "        if departure_time > 2359 or arrival_time > 2359:\n",
        "            raise ValueError(\"Time must be in HHMM format (e.g., 1345)\")\n",
        "        \"\"\"\n",
        "        This adds a new flight to the roster while keeping the list sorted\n",
        "        by departure time. We traverse from the head and find the correct\n",
        "        insertion position before linking the new node in.\n",
        "\n",
        "        \"\"\"\n",
        "        # We create the new node to be inserted.\n",
        "        new_node = FlightNode(flight_number, destination, departure_time, arrival_time)\n",
        "\n",
        "        # This is case 1 where the roster is empty. The new node becomes the head.\n",
        "        if self.head is None:\n",
        "            self.head = new_node\n",
        "            print(f\"  [ROSTER] Flight {flight_number} added as the first entry.\")\n",
        "            return\n",
        "\n",
        "        # This is case 2 where the new flight departs before all existing flights.\n",
        "        # We insert it at the front of the list.\n",
        "        if departure_time < self.head.departure_time:\n",
        "            new_node.next = self.head\n",
        "            self.head     = new_node\n",
        "            print(f\"  [ROSTER] Flight {flight_number} inserted at the beginning of the roster.\")\n",
        "            return\n",
        "\n",
        "        # In case 3 - We traverse the list to find the correct insertion position.\n",
        "        # We stop when the next node's departure time is greater than ours.\n",
        "        current = self.head\n",
        "        while current.next is not None and current.next.departure_time <= departure_time:\n",
        "            current = current.next\n",
        "\n",
        "        # We link the new node between current and current.next.\n",
        "        new_node.next = current.next\n",
        "        current.next  = new_node\n",
        "        print(f\"  [ROSTER] Flight {flight_number} inserted in chronological position.\")\n",
        "\n",
        "\n",
        "\n",
        "    # ----------------------------------------------------------------------------------------\n",
        "\n",
        "    # Operation 2: Cancel a flight.\n",
        "    def cancel_flight(self, flight_number):\n",
        "        \"\"\"\n",
        "        This function removes a flight from the roster by its flight number. We traverse\n",
        "        the list to locate the target node, then we relink surrounding nodes\n",
        "        to remove it from the chain.\n",
        "        \"\"\"\n",
        "        # We check whether the roster has any entries before proceeding.\n",
        "        if self.head is None:\n",
        "            print(\"  [ROSTER] The roster is empty. There is nothing to cancel.\")\n",
        "            return\n",
        "\n",
        "        # Case 1 -  The flight to cancel is at the head of the list.\n",
        "        if self.head.flight_number == flight_number:\n",
        "            self.head = self.head.next\n",
        "            print(f\"  [ROSTER] Flight {flight_number} has been cancelled successfully.\")\n",
        "            return\n",
        "\n",
        "        # Case 2 - We traverse the list looking for the node just before the target.\n",
        "        current = self.head\n",
        "        while current.next is not None:\n",
        "            if current.next.flight_number == flight_number:\n",
        "                # We bypass the target node by linking directly to the node after it.\n",
        "                current.next = current.next.next\n",
        "                print(f\"  [ROSTER] Flight {flight_number} has been cancelled successfully.\")\n",
        "                return\n",
        "            current = current.next\n",
        "\n",
        "        # If we reach here, the flight was not found in the roster.\n",
        "        print(f\"  [ROSTER] Flight {flight_number} was not found in the roster.\")\n",
        "\n",
        "    # ------------------------------------------------------------------------------------------\n",
        "\n",
        "    # Operation 3 - Validate rest gaps.\n",
        "    def validate_rest(self):\n",
        "        \"\"\"\n",
        "        This traverse the entire roster and check that every consecutive pair\n",
        "        of flights has a rest gap of at least 12 hours (720 minutes) between\n",
        "        the arrival of one flight and the departure of the next.\n",
        "\n",
        "        We also use the _to_minutes helper to convert HHMM values before comparing,\n",
        "        and we handle the edge case where the next flight departs after midnight.\n",
        "\n",
        "        \"\"\"\n",
        "        print(\"\\n  [VALIDATE] Starting rest gap validation...\")\n",
        "\n",
        "        # We cannot validate rest if there are fewer than two flights.\n",
        "        if self.head is None or self.head.next is None:\n",
        "            print(\"  [VALIDATE] Not enough flights to validate rest gaps.\")\n",
        "            return\n",
        "\n",
        "        # We assume all gaps are valid until we find a violation.\n",
        "        all_valid = True\n",
        "        current   = self.head\n",
        "\n",
        "        while current.next is not None:\n",
        "            # We convert both times to minutes for easy subtraction.\n",
        "            arrival_mins   = self._to_minutes(current.arrival_time)\n",
        "            departure_mins = self._to_minutes(current.next.departure_time)\n",
        "\n",
        "            # We handle the midnight crossing case. If the next flight's departure\n",
        "            # is numerically smaller than the current arrival, the next flight\n",
        "            # departs the following calendar day, so we add 24 hours (1440 minutes).\n",
        "            if departure_mins < arrival_mins:\n",
        "                departure_mins += 1440\n",
        "\n",
        "            gap = departure_mins - arrival_mins\n",
        "\n",
