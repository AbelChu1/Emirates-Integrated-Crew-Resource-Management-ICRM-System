        "                print(\n",
        "                    f\"  [VALIDATE] REST VIOLATION: Only {gap} minutes between \"\n",
        "                    f\"{current.flight_number} (arrives {current.arrival_time}) \"\n",
        "                    f\"and {current.next.flight_number} (departs {current.next.departure_time}).\"\n",
        "                )\n",
        "                all_valid = False\n",
        "            else:\n",
        "                # We confirm this pair satisfies the rest requirement.\n",
        "                print(\n",
        "                    f\"  [VALIDATE] OK: {gap} minutes rest between \"\n",
        "                    f\"{current.flight_number} and {current.next.flight_number}.\"\n",
        "                )\n",
        "\n",
        "            current = current.next\n",
        "\n",
        "        if all_valid:\n",
        "            print(\"  [VALIDATE] All rest gaps meet the 12-hour minimum requirement.\")\n",
        "        else:\n",
        "            print(\"  [VALIDATE] Validation complete. One or more violations were found.\")\n",
        "\n",
        "    # ------------------------------------------------------------------------------------\n",
        "\n",
        "    # Operation 4: Display roster.\n",
        "    def display_roster(self):\n",
        "        \"\"\"\n",
        "        This traverse the roster from head to tail and print each flight's details.\n",
        "        Because the list is kept in sorted order, this displays the schedule\n",
        "        in chronological order.\n",
        "        \"\"\"\n",
