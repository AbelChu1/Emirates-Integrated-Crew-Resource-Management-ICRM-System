        "            RETURN left\n",
        "\n",
        "        IF right.flight_id == flight_id:\n",
        "            PRINT \"Found from right:\", right.flight_id\n",
        "            RETURN right\n",
        "\n",
        "        IF left == right OR left.next == right:\n",
        "            BREAK\n",
        "\n",
        "        left  = left.next\n",
        "        right = right.prev\n",
        "\n",
        "    PRINT \"Flight not found.\"\n",
        "    RETURN None\n",
        "END FUNCTION\n",
        "```\n",
