        "    IF head is None:\n",
        "        head = new_node\n",
        "        tail = new_node\n",
        "        RETURN\n",
        "\n",
        "    new_node.prev = tail\n",
        "    tail.next     = new_node\n",
        "    tail          = new_node\n",
        "END FUNCTION\n",
        "```\n",
        "\n",
        "\n",
        "<br>\n",
